# --- Email reports (recommended — works without ClickUp) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REPORT_EMAIL_TO=

# --- ClickUp (optional — leave blank to skip) ---
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
CLICKUP_BASE_URL=https://api.clickup.com/api/v2

# --- Runtime / deployment mode ---
# development = local defaults; production = strict hosted/single-server posture.
NODE_ENV=development
PORT=3001
DATABASE_URL=file:./data/fieldpulse.sqlite

# Frontend build-time API origin. Leave empty for same-origin /api.
# Set to an absolute backend origin for hosted split-origin mode, for example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Backend CORS allowlist for hosted split-origin mode.
# Comma-separated frontend origins, no wildcard in production.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
