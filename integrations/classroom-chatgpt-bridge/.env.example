# OpenAI (API key from https://platform.openai.com/api-keys )
OPENAI_API_KEY=
# Model for drafts (e.g. gpt-4o-mini, gpt-4o)
OPENAI_MODEL=gpt-4o-mini

# Optional: path to AYA policy JSON (default ./config/aya-policy.json)
AYA_POLICY_PATH=./config/aya-policy.json

# Google OAuth (Desktop app) - or use client_secret.json from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect for installed app flow (must match Google Console)
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
